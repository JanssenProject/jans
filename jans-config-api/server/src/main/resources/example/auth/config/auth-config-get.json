{
    "issuer": "https://jans.example.com",
    "baseEndpoint": "https://jans.example.com/jans-auth/restv1",
    "authorizationEndpoint": "https://jans.example.com/jans-auth/restv1/authorize",
    "tokenEndpoint": "https://jans.example.com/jans-auth/restv1/token",
    "tokenRevocationEndpoint": "https://jans.example.com/jans-auth/restv1/revoke",
    "userInfoEndpoint": "https://jans.example.com/jans-auth/restv1/userinfo",
    "clientInfoEndpoint": "https://jans.example.com/jans-auth/restv1/clientinfo",
    "endSessionEndpoint": "https://jans.example.com/jans-auth/restv1/end_session",
    "jwksUri": "https://jans.example.com/jans-auth/restv1/jwks",
    "registrationEndpoint": "https://jans.example.com/jans-auth/restv1/register",
    "openIdDiscoveryEndpoint": "https://jans.example.com/.well-known/webfinger",
    "idGenerationEndpoint": "https://jans.example.com/jans-auth/restv1/id",
    "introspectionEndpoint": "https://jans.example.com/jans-auth/restv1/introspection",
    "sessionAsJwt": false,
    "sectorIdentifierCacheLifetimeInMinutes": 1440,
    "accessTokenLifetime": 300,
    "idTokenLifetime": 3600,
    "refreshTokenLifetime": 14400,
    "cleanServiceInterval": 60,
    "loggingLevel": "INFO",
    "loggingLayout": "text",
    "authenticationFiltersEnabled": false,
    "clientAuthenticationFiltersEnabled": false,
    "disableJdkLogger": true,
    "defaultSignatureAlgorithm": "RS256",
    "legacyIdTokenClaims": false,
    "customHeadersWithAuthorizationResponse": false,
    "featureFlags": [
        "HEALTH_CHECK",
        "USERINFO",
        "CLIENTINFO"
    ]
}
