namespace Jans {
  type Context = {
    current_time?: Long,
    device_health?: Set<String>,
    fraud_indicators?: Set<String>,
    geolocation?: Set<String>,
    network?: String,
    network_type?: String,
    operating_system?: String,
    tokens?: TokensContext,
    user_agent?: String
  };

  type TokensContext = {
    jans_access_token?: Jans::Access_token,
    jans_id_token?: Jans::id_token,
    jans_userinfo_token?: Jans::Userinfo_token,
    total_token_count: Long
  };

  type Url = {
    host: String,
    path: String,
    protocol: String
  };

  type email_address = {
    domain: String,
    uid: String
  };

  entity Access_token = {
    aud?: String,
    exp?: Long,
    iat?: Long,
    iss?: TrustedIssuer,
    jti?: String,
    nbf?: Long,
    scope?: Set<String>,
    token_type?: String,
    validated_at?: Long
  } tags Set<String>;

  entity Any;

  entity Application = {
    app_id?: String,
    name?: String,
    url?: Url
  };

  entity HTTP_Request = {
    header: {
      Accept?: String
    },
    url: Url
  };

  entity Role;

  entity TrustedIssuer = {
    issuer_entity_id: Url
  };

  entity Userinfo_token = {
    aud?: String,
    birthdate?: String,
    email?: email_address,
    exp?: Long,
    iat?: Long,
    iss?: TrustedIssuer,
    jti?: String,
    name?: String,
    phone_number?: String,
    role?: Set<String>,
    sub?: String,
    token_type?: String,
    validated_at?: Long
  } tags Set<String>;

  entity id_token = {
    acr?: String,
    amr?: Set<String>,
    aud?: Set<String>,
    azp?: String,
    birthdate?: String,
    email?: email_address,
    exp?: Long,
    iat?: Long,
    iss?: TrustedIssuer,
    jti?: String,
    name?: String,
    phone_number?: String,
    role?: Set<String>,
    sub?: String,
    token_type?: String,
    validated_at?: Long
  } tags Set<String>;

  action "Read" appliesTo {
    principal: [Any],
    resource: [Application],
    context: Context
  };

  action "Write" appliesTo {
    principal: [Any],
    resource: [Application],
    context: Context
  };
}
