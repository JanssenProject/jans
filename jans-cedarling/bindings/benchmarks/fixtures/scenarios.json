{
  "_schema_version": 1,
  "_doc": "Canonical benchmark fixtures. Shared by every binding. See bindings/benchmarks/CONTRACT.md.",
  "iteration_policy": {
    "warmup_iters": 100,
    "measure_iters": 1000
  },
  "scenarios": [
    {
      "id": "unsigned_simple",
      "doc": "Baseline unsigned authorize — 2-attr resource, 1-attr principal, empty context.",
      "kind": "unsigned",
      "policy_store_fn": "test_files/policy-store_ok_2.yaml",
      "config_overrides": {
        "CEDARLING_APPLICATION_NAME": "BenchmarkApp",
        "CEDARLING_JWT_SIG_VALIDATION": "disabled",
        "CEDARLING_JWT_STATUS_VALIDATION": "disabled",
        "CEDARLING_LOG_TYPE": "off"
      },
      "principal": {
        "cedar_entity_mapping": {
          "entity_type": "Jans::TestPrincipal1",
          "id": "test_principal_1"
        },
        "is_ok": true
      },
      "action": "Jans::Action::\"UpdateForTestPrincipals\"",
      "resource": {
        "cedar_entity_mapping": {
          "entity_type": "Jans::Issue",
          "id": "random_id"
        },
        "org_id": "some_long_id",
        "country": "US"
      },
      "context": "{}",
      "tokens": [],
      "mock_op_required": false
    },
    {
      "id": "unsigned_deep_json",
      "doc": "Unsigned authorize with a structured nested context — stresses build_context / Value-clone cost. Uses a bench-specific policy store whose action declares a matching context shape (Cedar requires context shape to be declared in the schema).",
      "kind": "unsigned",
      "policy_store_fn": "test_files/policy-store-bench-deep.yaml",
      "config_overrides": {
        "CEDARLING_APPLICATION_NAME": "BenchmarkApp",
        "CEDARLING_JWT_SIG_VALIDATION": "disabled",
        "CEDARLING_JWT_STATUS_VALIDATION": "disabled",
        "CEDARLING_LOG_TYPE": "off"
      },
      "principal": {
        "cedar_entity_mapping": {
          "entity_type": "Jans::TestPrincipal1",
          "id": "test_principal_1"
        },
        "is_ok": true
      },
      "action": "Jans::Action::\"UpdateDeep\"",
      "resource": {
        "cedar_entity_mapping": {
          "entity_type": "Jans::Issue",
          "id": "random_id"
        },
        "org_id": "some_long_id",
        "country": "US"
      },
      "context": "{\"request\":{\"id\":\"req-deepjson-001\",\"method\":\"POST\",\"path\":\"/api/v1/issues\"},\"geo\":{\"country\":\"US\",\"region\":\"CA\",\"city\":\"San Francisco\",\"asn\":15169},\"timestamps\":{\"received_at\":1700000000,\"deadline_ms\":250},\"tags\":[\"benchmark\",\"deep_json\",\"cross_platform\"]}",
      "tokens": [],
      "mock_op_required": false
    },
    {
      "id": "multi_issuer_2_tokens",
      "doc": "Multi-issuer authorize with 2 token mappings (mirrors cedarling criterion bench).",
      "kind": "multi_issuer",
      "policy_store_fn": "test_files/policy-store-multi-issuer-test.yaml",
      "config_overrides": {
        "CEDARLING_APPLICATION_NAME": "BenchmarkApp",
        "CEDARLING_JWT_SIG_VALIDATION": "disabled",
        "CEDARLING_JWT_STATUS_VALIDATION": "disabled",
        "CEDARLING_JWT_SIGNATURE_ALGORITHMS_SUPPORTED": ["HS256"],
        "CEDARLING_LOG_TYPE": "off"
      },
      "principal": null,
      "action": "Jans::Action::\"Update\"",
      "resource": {
        "cedar_entity_mapping": {
          "entity_type": "Jans::Issue",
          "id": "random_id"
