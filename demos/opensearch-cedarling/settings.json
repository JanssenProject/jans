{
    "bootstrapProperties": {
        "CEDARLING_APPLICATION_NAME": "Cedarling OpenSearch demo",
        "CEDARLING_JWT_SIG_VALIDATION": "enabled",
        "CEDARLING_JWT_STATUS_VALIDATION": "enabled",
        "CEDARLING_JWT_SIGNATURE_ALGORITHMS_SUPPORTED": [
            "HS256",
            "RS256"
        ],
        "CEDARLING_LOG_TYPE": "memory",
        "CEDARLING_LOG_LEVEL": "INFO",
        "CEDARLING_LOG_TTL": 60,
        "CEDARLING_POLICY_STORE_URI": "https://path/to/cjar"
    },
    "searchActionName": "Jans::Action::\"Search\"",
    "schemaPrefix": "Jans",
    "enabled": true,
    "logCedarlingLogs": true
}
