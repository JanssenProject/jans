<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.1.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.1.0
              http://maven.apache.org/xsd/assembly-2.1.0.xsd">
    <id>lock-policy-store</id>
    <formats>
        <format>zip</format>
    </formats>
    <!-- Files must sit at the ROOT of the archive (no wrapping directory), so
         the Cedarling archive loader finds metadata.json / policies/ in root. -->
    <includeBaseDirectory>false</includeBaseDirectory>
    <fileSets>
        <fileSet>
            <directory>${project.basedir}/src/main/policy_store</directory>
            <outputDirectory>.</outputDirectory>
            <includes>
                <include>metadata.json</include>
                <include>schema.cedarschema</include>
                <include>policies/**</include>
                <include>trusted-issuers/**</include>
            </includes>
        </fileSet>
    </fileSets>
</assembly>
